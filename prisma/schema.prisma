generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  companyName  String
  passwordHash String
  otp          String
  otpExpiry    DateTime
  createdAt    DateTime @default(now())

  @@map("pending_registrations")
}

model Tenant {
  id                     String                  @id @default(uuid())
  name                   String
  domain                 String?                 @unique
  createdAt              DateTime                @default(now())
  leadAssigneeIndex      Int                     @default(0)
  displayCurrency        String                  @default("USD")
  taxRate                Float                   @default(0)
  companyProfile         Json?
  seatLimit              Int                     @default(5)
  stripeCustomerId       String?
  subscriptionId         String?
  activities             Activity[]
  announcements          Announcement[]
  attendances            Attendance[]
  billingEvents          BillingEvent[]
  customFieldDefinitions CustomFieldDefinition[]
  customRoles            CustomRole[]
  customers              Customer[]
  deals                  Deal[]
  departments            Department[]
  designations           Designation[]
  employeeProfiles       EmployeeProfile[]
  expenses               Expense[]
  invoices               Invoice[]
  leads                  Lead[]
  leaveRequests          LeaveRequest[]
  notifications          Notification[]
  payslips               Payslip[]
  products               Product[]
  prospects              ProspectMeta[]
  salaryStructures       SalaryStructure[]
  systemActivities       SystemActivity[]
  subscription           TenantSubscription?
  users                  User[]
}

model User {
  id                      String                    @id @default(uuid())
  tenantId                String
  name                    String
  email                   String                    @unique
  passwordHash            String
  role                    Role                      @default(EMPLOYEE)
  createdAt               DateTime                  @default(now())
  customRoleId            String?
  isEmailVerified         Boolean                   @default(false)
  otp                     String?
  otpExpiry               DateTime?
  workspaceId             String?                   @unique
  fcmToken                String?
  nextSalaryReimbursement Float                     @default(0)
  stripeCustomerId        String?
  activities              Activity[]
  announcements           Announcement[]
  deals                   Deal[]
  managedEmployees        EmployeeProfile[]         @relation("EmployeeManager")
  employeeProfile         EmployeeProfile?
  expenses                Expense[]
  assignedLeads           Lead[]                    @relation("LeadAssignee")
  createdLeads            Lead[]                    @relation("LeadCreator")
  approvedLeaves          LeaveRequest[]            @relation("LeaveApprover")
  notifications           Notification[]
  createdProspects        ProspectMeta[]            @relation("ProspectCreator")
  pushSubscriptions       PushSubscription[]
  systemActivities        SystemActivity[]
  toolUser                ToolUser?
  messages                Message[]
  participants            ConversationParticipant[]
  customRole              CustomRole?               @relation(fields: [customRoleId], references: [id])
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation            Conversation[]
  @@index([tenantId])
}

model Customer {
  id           String     @id @default(uuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  status       String     @default("LEAD")
  createdAt    DateTime   @default(now())
  address      String?
  city         String?
  country      String?
  gstin        String?
  pinCode      String?
  state        String?
  customFields Json?
  activities   Activity[]
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@index([tenantId])
}

model Expense {
  id            String        @id @default(uuid())
  tenantId      String
  userId        String
  customerId    String?
  title         String
  description   String?
  category      String?
  amount        Float
  currency      Currency      @default(USD)
  status        ExpenseStatus @default(PENDING)
  spentAt       DateTime      @default(now())
  proofUrl      String?
  proofPath     String?
  proofFileName String?
  proofMimeType String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      Customer?     @relation(fields: [customerId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([customerId])
  @@index([spentAt])
  @@index([status])
}

model Deal {
  id            String     @id @default(uuid())
  tenantId      String
  title         String
  value         Float
  stage         String     @default("LEAD")
  assignedTo    String?
  createdAt     DateTime   @default(now())
  currency      String     @default("USD")
  leadId        String?    @unique
  company       String?
  contactPerson String?
  email         String?
  phone         String?
  tokenAmount   Float      @default(0)
  customFields  Json?
  activities    Activity[]
  user          User?      @relation(fields: [assignedTo], references: [id])
  lead          Lead?      @relation(fields: [leadId], references: [id])
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       Invoice?

  @@index([tenantId])
  @@index([leadId])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model Activity {
  id          String       @id @default(uuid())
  tenantId    String
  type        ActivityType @default(TASK)
  title       String
  notes       String?
  dueDate     DateTime?
  completedAt DateTime?
  customerId  String?
  dealId      String?
  userId      String
  createdAt   DateTime     @default(now())
  customer    Customer?    @relation(fields: [customerId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([dealId])
  @@index([userId])
}

model SystemActivity {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  details    String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model Department {
  id          String            @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees   EmployeeProfile[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Designation {
  id          String            @id @default(uuid())
  tenantId    String
  title       String
  level       Int               @default(1)
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees   EmployeeProfile[]

  @@unique([tenantId, title])
  @@index([tenantId])
}

model EmployeeProfile {
  id               String           @id @default(uuid())
  tenantId         String
  userId           String           @unique
  departmentId     String?
  designationId    String?
  managerId        String?
  employeeCode     String?
  gender           String?
  dob              DateTime?
  phone            String?
  address          String?
  emergencyContact String?
  bloodGroup       String?
  joiningDate      DateTime?
  probationEndDate DateTime?
  employmentType   String           @default("FULL_TIME")
  workLocation     String           @default("OFFICE")
  employeeStatus   String           @default("ACTIVE")
  basicSalary      Float?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  customFields     Json?
  weeklyOffs       Int              @default(2)
  workScheduleType WorkScheduleType @default(FIXED)
  workingDays      Json?
  attendances      Attendance[]
  department       Department?      @relation(fields: [departmentId], references: [id])
  designation      Designation?     @relation(fields: [designationId], references: [id])
  manager          User?            @relation("EmployeeManager", fields: [managerId], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveRequests    LeaveRequest[]   @relation("EmployeeLeaves")
  payslips         Payslip[]
  salaryStructure  SalaryStructure?

  @@index([tenantId])
  @@index([departmentId])
  @@index([managerId])
}

model CustomFieldDefinition {
  id         String  @id @default(uuid())
  tenantId   String
  entityType String
  fieldName  String
  fieldLabel String
  fieldType  String
  isRequired Boolean @default(false)
  options    Json?
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, fieldName])
  @@index([tenantId])
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  dealId         String        @unique
  invoiceNo      String
  clientName     String
  clientEmail    String?
  amount         Float
  currency       String        @default("USD")
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  totalAmount    Float
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  sentAt         DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  clientAddress  String?
  clientCity     String?
  clientCountry  String?
  clientGstin    String?
  clientPhone    String?
  clientPinCode  String?
  clientState    String?
  creditNote     String?
  sacCode        String?       @default("998313")
  subtotalAmount Float?
  taxConfigId    String?
  deal           Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model CustomRole {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@index([tenantId])
}

model Lead {
  id                String       @id @default(uuid())
  tenantId          String
  firstName         String
  lastName          String?
  email             String?
  phone             String?
  company           String?
  jobTitle          String?
  source            LeadSource   @default(OTHER)
  status            LeadStatus   @default(NEW)
  priority          LeadPriority @default(MEDIUM)
  estimatedValue    Float?
  notes             String?
  assignedToId      String?
  createdById       String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  currency          String       @default("USD")
  interestedProduct String?
  address           String?
  city              String?
  country           String?
  gstin             String?
  pinCode           String?
  state             String?
  deal              Deal?
  assignedTo        User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  createdBy         User         @relation("LeadCreator", fields: [createdById], references: [id])
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assignedToId])
  @@index([createdById])
}

model ProspectMeta {
  id           String           @id @default(uuid())
  tenantId     String
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  source       String?
  sourceDetail String?
  status       ProspectStatus   @default(NEW)
  priority     ProspectPriority @default(MEDIUM)
  customFields Json?
  detail       ProspectDetail?
  createdBy    User             @relation("ProspectCreator", fields: [createdById], references: [id])
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdById])
}

model ProspectDetail {
  id              String                @id @default(uuid())
  prospectMetaId  String                @unique
  name            String
  email           String?
  phone           String?
  company         String?
  companySize     String?
  budget          Float?
  serviceInterest String?
  requirements    String?
  lastContact     DateTime?
  nextFollowup    DateTime?
  linkedin        String?
  notes           String?
  currency        Currency              @default(USD)
  contactMethod   ProspectContactMethod @default(EMAIL)
  prospectMeta    ProspectMeta          @relation(fields: [prospectMetaId], references: [id], onDelete: Cascade)
}

model Product {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  sku          String?
  description  String?
  price        Float
  currency     Currency @default(USD)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customFields Json?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ToolUser {
  id            String              @id @default(uuid())
  sessionId     String?             @unique
  email         String?             @unique
  passwordHash  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  crmUserId     String?             @unique
  credits       StandaloneCredit[]
  invoices      StandaloneInvoice[]
  passPurchases ToolPassPurchase[]
  purchases     ToolPurchase[]
  usages        ToolUsage[]
  crmUser       User?               @relation(fields: [crmUserId], references: [id])
}

model ToolUsage {
  id         String   @id @default(uuid())
  toolUserId String
  tool       String
  usageCount Int      @default(0)
  period     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  toolUser   ToolUser @relation(fields: [toolUserId], references: [id], onDelete: Cascade)

  @@index([toolUserId])
}

model ToolPurchase {
  id         String    @id @default(uuid())
  toolUserId String
  tool       String
  type       String
  currency   String    @default("INR")
  amount     Float
  status     String    @default("COMPLETED")
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  toolUser   ToolUser  @relation(fields: [toolUserId], references: [id], onDelete: Cascade)

  @@index([toolUserId])
}

model StandaloneInvoice {
  id                     String    @id @default(uuid())
  toolUserId             String
  invoiceNo              String
  clientName             String
  clientEmail            String?
  clientAddress          String?
  amount                 Float
  currency               String    @default("INR")
  taxRate                Float     @default(0)
  taxAmount              Float     @default(0)
  totalAmount            Float
  dueDate                DateTime?
  items                  Json
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  senderAddress          String?
  senderEmail            String?
  senderName             String?
  clientPhone            String?
  senderBusinessCategory String?
  senderGstin            String?
  senderPan              String?
  senderPhone            String?
  invoiceDate            DateTime  @default(now())
  logoUrl                String?
  templateId             String    @default("basic")
  clientGstin            String?
  clientPan              String?
  toolUser               ToolUser  @relation(fields: [toolUserId], references: [id], onDelete: Cascade)

  @@index([toolUserId])
}

model ScheduledEmail {
  id          String    @id @default(cuid())
  tenantId    String
  createdById String
  to          String
  toName      String    @default("")
  subject     String
  htmlBody    String
  scheduledAt DateTime
  status      String    @default("PENDING")
  sentAt      DateTime?
  errorMsg    String?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([status, scheduledAt])
}

model Campaign {
  id          String              @id @default(cuid())
  tenantId    String
  createdById String
  name        String
  subject     String
  htmlBody    String
  status      String              @default("DRAFT")
  scheduledAt DateTime?
  totalSent   Int                 @default(0)
  totalFailed Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  recipients  CampaignRecipient[]

  @@index([tenantId])
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  email      String
  name       String?
  entityType String?
  entityId   String?
  status     String    @default("PENDING")
  errorMsg   String?
  sentAt     DateTime?
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
}

model Attendance {
  id                String          @id @default(uuid())
  tenantId          String
  employeeProfileId String
  date              DateTime
  checkIn           DateTime?
  checkOut          DateTime?
  totalHours        Float?
  overtimeHours     Float           @default(0)
  status            String          @default("PRESENT")
  workMode          String          @default("OFFICE")
  remarks           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employeeProfile   EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeProfileId])
  @@index([date])
}

model LeaveRequest {
  id                String          @id @default(uuid())
  tenantId          String
  employeeProfileId String
  leaveType         String
  startDate         DateTime
  endDate           DateTime
  totalDays         Float
  reason            String
  status            String          @default("PENDING")
  approvedById      String?
  managerRemarks    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  approvedBy        User?           @relation("LeaveApprover", fields: [approvedById], references: [id])
  employeeProfile   EmployeeProfile @relation("EmployeeLeaves", fields: [employeeProfileId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeProfileId])
}

model SalaryStructure {
  id                String          @id @default(uuid())
  tenantId          String
  employeeProfileId String          @unique
  basicPay          Float
  hra               Float           @default(0)
  conveyance        Float           @default(0)
  medicalAllowance  Float           @default(0)
  specialAllowance  Float           @default(0)
  providentFund     Float           @default(0)
  professionalTax   Float           @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employeeProfile   EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Payslip {
  id                String          @id @default(uuid())
  tenantId          String
  employeeProfileId String
  month             Int
  year              Int
  basicPay          Float
  allowances        Json
  deductions        Json
  reimbursements    Float           @default(0)
  netPay            Float
  status            String          @default("DRAFT")
  pdfUrl            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employeeProfile   EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeProfileId])
  @@index([month, year])
}

model PricingPlan {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  description   String?
  isActive      Boolean              @default(true)
  sortOrder     Int                  @default(0)
  features      Json
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  seatTiers     SeatTier[]
  subscriptions TenantSubscription[]
}

model SeatTier {
  id                   String               @id @default(cuid())
  planId               String
  label                String
  minSeats             Int
  maxSeats             Int
  baseAmountInr        Decimal
  baseAmountUsd        Decimal
  yearlyAmountInr      Decimal
  yearlyAmountUsd      Decimal
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  plan                 PricingPlan          @relation(fields: [planId], references: [id])
  subscriptions        TenantSubscription[]
}

model TaxConfig {
  id            String   @id @default(cuid())
  name          String
  region        String
  taxType       String
  rate          Decimal
  isActive      Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  planId               String
  seatTierId           String
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus @default(TRIALING)
  billingCycle         BillingCycle       @default(MONTHLY)
  currency             String             @default("INR")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  seatsUsed            Int                @default(1)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  latestInvoiceUrl     String?
  billingEvents        BillingEvent[]
  plan                 PricingPlan        @relation(fields: [planId], references: [id])
  seatTier             SeatTier           @relation(fields: [seatTierId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
}

model BillingEvent {
  id              String              @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  type            BillingEventType
  amountInr       Decimal?
  amountUsd       Decimal?
  currency        String?
  stripeEventId   String?             @unique
  stripeInvoiceId String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  subscription    TenantSubscription? @relation(fields: [subscriptionId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  discountType   DiscountType
  value          Decimal
  maxUses        Int?
  usedCount      Int                @default(0)
  expiresAt      DateTime?
  planIds        Json?
  stripeCouponId String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  redemptions    CouponRedemption[]
}

model CouponRedemption {
  id               String   @id @default(cuid())
  couponId         String
  tenantId         String
  discountApplied  Decimal
  stripeDiscountId String?
  redeemedAt       DateTime @default(now())
  coupon           Coupon   @relation(fields: [couponId], references: [id])
}

model ToolProduct {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  freeUsageLimit Int               @default(5)
  isActive       Boolean           @default(true)
  description    String?
  passes         ToolPassProduct[]
}

model ToolPassProduct {
  id            String             @id @default(cuid())
  toolProductId String
  name          String
  passType      PassType
  usageLimit    Int?
  priceInr      Decimal
  priceUsd      Decimal
  stripePriceId String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  toolProduct   ToolProduct        @relation(fields: [toolProductId], references: [id])
  purchases     ToolPassPurchase[]
}

model ToolPassPurchase {
  id                    String             @id @default(cuid())
  toolUserId            String
  toolPassProductId     String
  stripePaymentIntentId String?
  stripeSessionId       String?
  status                PurchaseStatus     @default(PENDING)
  purchasedAt           DateTime?
  expiresAt             DateTime?
  usageCount            Int                @default(0)
  amountPaid            Decimal
  currency              String
  createdAt             DateTime           @default(now())
  credits               StandaloneCredit[]
  toolPassProduct       ToolPassProduct    @relation(fields: [toolPassProductId], references: [id])
  toolUser              ToolUser           @relation(fields: [toolUserId], references: [id], onDelete: Cascade)
}

model StandaloneCredit {
  id                         String           @id @default(cuid())
  toolUserId                 String
  toolPassPurchaseId         String
  originalAmount             Decimal
  creditableAmount           Decimal
  status                     CreditStatus     @default(PENDING)
  appliedToSubscriptionId    String?
  appliedAt                  DateTime?
  expiresAt                  DateTime
  stripeBalanceTransactionId String?
  createdAt                  DateTime         @default(now())
  toolPassPurchase           ToolPassPurchase @relation(fields: [toolPassPurchaseId], references: [id], onDelete: Cascade)
  toolUser                   ToolUser         @relation(fields: [toolUserId], references: [id], onDelete: Cascade)
}

