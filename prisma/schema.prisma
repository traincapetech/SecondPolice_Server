generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Temporarily holds registration data until email is verified.
// Deleted once OTP is confirmed and the real Tenant+User are created.
model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  companyName  String
  passwordHash String
  otp          String
  otpExpiry    DateTime
  createdAt    DateTime @default(now())

  @@map("pending_registrations")
}

model Tenant {
  id                String         @id @default(uuid())
  name              String
  domain            String?        @unique
  createdAt         DateTime       @default(now())
  leadAssigneeIndex Int            @default(0)
  displayCurrency   String         @default("USD")
  taxRate           Float          @default(0)
  companyProfile    Json?          // { businessCategory, address, city, state, pinCode, country, gstin, pan, companyEmail, companyPhone, logoUrl }
  users             User[]
  customers         Customer[]
  deals             Deal[]
  activities        Activity[]
  customRoles       CustomRole[]
  leads             Lead[]
  notifications     Notification[]
  invoices          Invoice[]
  prospects         ProspectMeta[]
  products          Product[]
  expenses          Expense[]
  systemActivities  SystemActivity[]
  announcements     Announcement[]
  departments       Department[]
  designations      Designation[]
  employeeProfiles  EmployeeProfile[]
  attendances       Attendance[]
  leaveRequests     LeaveRequest[]
}

model User {
  id           String         @id @default(uuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String         @unique
  passwordHash    String
  isEmailVerified Boolean        @default(false)
  otp             String?
  otpExpiry       DateTime?
  role            Role           @default(EMPLOYEE)
  workspaceId     String?        @unique
  createdAt       DateTime       @default(now())
  nextSalaryReimbursement Float  @default(0) // Added for expense claim reimbursements
  deals        Deal[]
  activities   Activity[]
  notifications Notification[]
  systemActivities SystemActivity[]
  announcements Announcement[]
  employeeProfile  EmployeeProfile?
  managedEmployees EmployeeProfile[] @relation("EmployeeManager")
  customRoleId String?
  customRole   CustomRole?    @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  assignedLeads Lead[]        @relation("LeadAssignee")
  createdLeads  Lead[]        @relation("LeadCreator")
  createdProspects ProspectMeta[] @relation("ProspectCreator")
  expenses      Expense[]
  pushSubscriptions PushSubscription[]
  toolUser      ToolUser?
  fcmToken      String?
  approvedLeaves LeaveRequest[] @relation("LeaveApprover")

  @@index([tenantId])
}

model Customer {
  id         String     @id @default(uuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  pinCode    String?
  country    String?
  gstin      String?
  status     String     @default("LEAD")
  createdAt  DateTime   @default(now())
  activities Activity[]
  expenses   Expense[]

  @@index([tenantId])
}

model Expense {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  title         String
  description   String?
  category      String?
  amount        Float
  currency      Currency @default(USD)
  status        ExpenseStatus @default(PENDING)
  spentAt       DateTime @default(now())
  proofUrl      String?
  proofPath     String?
  proofFileName String?
  proofMimeType String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([customerId])
  @@index([spentAt])
  @@index([status])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

model Deal {
  id         String     @id @default(uuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  value      Float
  tokenAmount Float      @default(0)
  currency   String     @default("USD")
  stage      String     @default("LEAD")
  assignedTo String?
  user       User?      @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  leadId     String?    @unique   // nullable; set when auto-created from a Lead conversion
  lead       Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  // Standalone contact info (for deals not linked to leads)
  contactPerson String?
  company       String?
  email         String?
  phone         String?

  createdAt  DateTime   @default(now())
  activities Activity[]
  invoice    Invoice?

  @@index([tenantId])
  @@index([leadId])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // e.g. LEAD_ASSIGNED
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
}

model Activity {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        ActivityType @default(TASK)
  title       String
  notes       String?
  dueDate     DateTime?
  completedAt DateTime?
  customerId  String?
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([dealId])
  @@index([userId])
}

model SystemActivity {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String
  details     String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

model Announcement {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  content     String   @db.Text
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

// ============================================================================
// HRMS MODULE — Phase 1: Foundation & Employee Management
// ============================================================================

model Department {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  description String?
  employees   EmployeeProfile[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Designation {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  level       Int               @default(1)  // 1=Junior … 5=Senior/Lead
  description String?
  employees   EmployeeProfile[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, title])
  @@index([tenantId])
}

model EmployeeProfile {
  id              String       @id @default(uuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 1-to-1 link to User (auth, email, name live there)
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hierarchy
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId   String?
  designation     Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  managerId       String?      // points to another EmployeeProfile.userId
  manager         User?        @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Personal info
  employeeCode    String?      // e.g. EMP-0001
  gender          String?
  dob             DateTime?
  phone           String?
  address         String?
  emergencyContact String?
  bloodGroup      String?

  // Employment info
  joiningDate     DateTime?
  probationEndDate DateTime?
  employmentType  String       @default("FULL_TIME")  // FULL_TIME | PART_TIME | CONTRACT | INTERN
  workLocation    String       @default("OFFICE")    // OFFICE | REMOTE | HYBRID
  employeeStatus  String       @default("ACTIVE")    // ACTIVE | PROBATION | NOTICE_PERIOD | TERMINATED

  // Salary (basic; detailed structure comes in Phase 3)
  basicSalary     Float?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  attendances     Attendance[]
  leaveRequests   LeaveRequest[] @relation("EmployeeLeaves")

  @@index([tenantId])
  @@index([departmentId])
  @@index([managerId])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId      String        @unique
  deal        Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  invoiceNo   String
  clientName  String
  clientEmail String?
  clientPhone String?
  clientAddress String?
  clientCity  String?
  clientState String?
  clientPinCode String?
  clientCountry String?
  clientGstin String?
  amount      Float
  currency    String        @default("USD")
  taxRate     Float         @default(0)
  taxAmount   Float         @default(0)
  totalAmount Float
  dueDate     DateTime
  status      InvoiceStatus @default(DRAFT)
  sentAt      DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([status])
}

model CustomRole {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  permissions Json
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Lead {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Contact info
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  company        String?
  jobTitle       String?
  address        String?
  city           String?
  state          String?
  pinCode        String?
  country        String?
  gstin          String?

  // Lead details
  source         LeadSource   @default(OTHER)
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  estimatedValue Float?
  currency       String       @default("USD")
  interestedProduct String?
  notes          String?

  // Assignment
  assignedToId   String?
  assignedTo     User?        @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User         @relation("LeadCreator", fields: [createdById], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deal           Deal?                        // auto-created deal when converted

  @@index([tenantId])
  @@index([assignedToId])
  @@index([createdById])
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EMAIL
  SOCIAL_MEDIA
  ADVERTISEMENT
  EVENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model ProspectMeta {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User           @relation("ProspectCreator", fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  source         String?
  sourceDetail   String?
  status         ProspectStatus   @default(NEW)
  priority       ProspectPriority @default(MEDIUM)
  detail         ProspectDetail?

  @@index([tenantId])
  @@index([createdById])
}

model ProspectDetail {
  id              String       @id @default(uuid())
  prospectMetaId  String       @unique
  prospectMeta    ProspectMeta @relation(fields: [prospectMetaId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  company         String?
  companySize     String?
  budget          Float?
  currency        Currency             @default(USD)
  serviceInterest String?
  requirements    String?
  lastContact     DateTime?
  nextFollowup    DateTime?
  contactMethod   ProspectContactMethod @default(EMAIL)
  linkedin        String?
  notes           String?
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}

enum ProspectPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProspectContactMethod {
  EMAIL
  PHONE
  WHATSAPP
  LINKEDIN
  OTHER
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AED
  JPY
  CAD
  AUD
  SGD
  SAR
}

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  description String?
  price       Float
  currency    Currency @default(USD)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// Stores browser Web Push subscriptions (one per browser/device per user)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique   // browser push service URL — unique per device
  p256dh    String             // encryption key
  auth      String             // auth secret
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// MICRO-PRODUCT / STANDALONE TOOLS LAYER
// ============================================================================

model ToolUser {
  id           String   @id @default(uuid())
  sessionId    String?  @unique // For anonymous usage tracking
  email        String?  @unique // Nullable if they haven't logged in yet
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usages       ToolUsage[]
  purchases    ToolPurchase[]
  invoices     StandaloneInvoice[]

  // Optional link to CRM User if they convert later
  crmUserId    String?  @unique
  crmUser      User?    @relation(fields: [crmUserId], references: [id])
}

model ToolUsage {
  id         String   @id @default(uuid())
  toolUserId String
  toolUser   ToolUser @relation(fields: [toolUserId], references: [id], onDelete: Cascade)
  tool       String   // e.g. "INVOICE"
  usageCount Int      @default(0)
  period     String?  // e.g. "LIFETIME", "WEEKLY", "MONTHLY"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([toolUserId])
}

model ToolPurchase {
  id         String   @id @default(uuid())
  toolUserId String
  toolUser   ToolUser @relation(fields: [toolUserId], references: [id], onDelete: Cascade)
  tool       String   // e.g. "INVOICE"
  type       String   // e.g. "WEEKLY_PASS", "PER_INVOICE"
  currency   String   @default("INR")
  amount     Float
  status     String   @default("COMPLETED")
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([toolUserId])
}

model StandaloneInvoice {
  id            String   @id @default(uuid())
  toolUserId    String
  toolUser      ToolUser @relation(fields: [toolUserId], references: [id], onDelete: Cascade)
  
  invoiceNo     String
  clientName    String
  clientEmail   String?
  clientAddress String?
  
  senderName             String?
  senderEmail            String?
  senderAddress          String?
  senderPhone            String?
  senderGstin            String?
  senderPan              String?
  senderBusinessCategory String?
  logoUrl                String?

  clientPhone   String?

  amount        Float
  currency      String   @default("INR")
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float
  dueDate       DateTime?
  
  items         Json     // Array of invoice items
  notes         String?
  
  templateId    String   @default("basic")
  invoiceDate   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toolUserId])
}

// Stores emails that should be delivered at a future scheduled time.
// Picked up by POST /api/jobs/run-scheduled-emails every minute (via cron-job.org).
model ScheduledEmail {
  id          String    @id @default(cuid())
  tenantId    String
  createdById String                        // user who scheduled it
  to          String                        // recipient email address
  toName      String    @default("")
  subject     String
  htmlBody    String    @db.Text
  scheduledAt DateTime                      // when to deliver
  status      String    @default("PENDING") // PENDING | SENT | FAILED | CANCELLED
  sentAt      DateTime?
  errorMsg    String?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([status, scheduledAt])
}

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String
  name        String   // Internal name
  subject     String   // Email subject
  htmlBody    String   @db.Text
  status      String   @default("DRAFT") // DRAFT, SENDING, SENT, SCHEDULED
  scheduledAt DateTime?
  
  totalSent   Int      @default(0)
  totalFailed Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  recipients  CampaignRecipient[]

  @@index([tenantId])
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  email      String
  name       String?
  
  entityType String?  // "LEAD" or "CUSTOMER"
  entityId   String?
  
  status     String   @default("PENDING") // PENDING, SENT, FAILED
  errorMsg   String?
  sentAt     DateTime?

  @@index([campaignId])
  @@index([status])
}

// ─── HRMS PHASE 2: ATTENDANCE & LEAVES ────────────────────────────────────

model Attendance {
  id                String          @id @default(uuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeProfileId String
  employeeProfile   EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  
  date              DateTime        // The calendar date of this record (normalized to start of day)
  checkIn           DateTime?       // Actual check-in timestamp
  checkOut          DateTime?       // Actual check-out timestamp
  totalHours        Float?          // Calculated hours between checkIn and checkOut
  overtimeHours     Float           @default(0)
  status            String          @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, LEAVE, HOLIDAY
  workMode          String          @default("OFFICE")  // OFFICE, REMOTE
  remarks           String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([tenantId])
  @@index([employeeProfileId])
  @@index([date])
}

model LeaveRequest {
  id                String          @id @default(uuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeProfileId String
  employeeProfile   EmployeeProfile @relation("EmployeeLeaves", fields: [employeeProfileId], references: [id], onDelete: Cascade)
  
  leaveType         String          // CASUAL, SICK, EARNED, UNPAID, MATERNITY
  startDate         DateTime
  endDate           DateTime
  totalDays         Float
  reason            String
  status            String          @default("PENDING") // PENDING, APPROVED, REJECTED
  
  approvedById      String?
  approvedBy        User?           @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  managerRemarks    String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([tenantId])
  @@index([employeeProfileId])
}
